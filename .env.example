GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_PAT=ghp_your-fine-grained-pat
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

DATABASE_URL=sqlite+aiosqlite:///./security_scout.db
REDIS_URL=redis://localhost:6379
LOG_LEVEL=INFO

# pytest @pytest.mark.postgres suite (`make check`, `pytest -m postgres`). Matches docker-compose postgres service.
# POSTGRES_TEST_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres

# Optional: triage LLM refinement (Sonnet tier)
# ANTHROPIC_API_KEY=
# Path to repos manifest (default: ./repos.yaml)
# REPOS_CONFIG_PATH=/absolute/path/to/repos.yaml

# Optional: scheduled repository advisory list poll (ARQ job `sync_repository_advisories`).
# ADVISORY_POLL_INTERVAL=disabled
# Presets: disabled | every_5_min | every_15_min | hourly | every_4_hours | daily
# Default is disabled. When enabling polling, `hourly` is a reasonable starting cadence.
# Per-repo `advisory_poll_states` in repos.yaml defaults to [triage]; set `advisory_poll_states: []` to skip a repo.
# ADVISORY_POLL_MAX_ENQUEUES_PER_TICK_GLOBAL=100
# ADVISORY_POLL_RATE_PER_HOUR=500
#
# Fine-grained GitHub PAT: grant read access to **Repository security advisories** for each monitored repo (and
# **Metadata** read). Private repos need appropriate repository content/access scopes. Classic PATs need `repo` for
# private repositories. The app does not introspect PAT scopes at runtime (fine-grained tokens are not introspectable);
# permission verification is planned for the GitHub App path (see ADR-032 in documentation/decisions.md).

# Issue tracker credentials (JIRA Cloud/Server and Linear)
# JIRA_API_EMAIL=ops@acme.io
# JIRA_API_TOKEN=
# LINEAR_API_KEY=

# MCP read-only server: JSON array of client identifiers allowed (empty = allow all)
# MCP_CLIENT_ALLOWLIST=["cursor","claude-code"]

# PoC sandbox (Docker or Podman API socket)
# CONTAINER_SOCKET=unix:///var/run/docker.sock
# Podman (rootless): unix:///run/user/1000/podman/podman.sock
# Optional: path to seccomp JSON when not using repo checkout (default: sandbox/seccomp.json)
# SECURITY_SCOUT_SECCOMP=/opt/security-scout/sandbox/seccomp.json


POSTGRES_USER=scout
POSTGRES_DB=security_scout

CADDY_DOMAIN=scout.example.com
CADDY_EMAIL=ops@example.com

SCOUT_IMAGE=securityscout:local
